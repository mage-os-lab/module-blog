<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="product.info.details">
            <block class="Magento\Framework\View\Element\Template"
                   name="mageos_blog.product.related_posts"
                   template="MageOS_Blog::product/related-posts.phtml"
                   group="detailed_info">
                <arguments>
                    <argument name="title" translate="true" xsi:type="string">Related Posts</argument>
                </arguments>
            </block>
        </referenceContainer>
    </body>
</page>
