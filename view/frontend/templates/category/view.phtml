<?php

declare(strict_types=1);

/** @var \MageOS\Blog\Block\Category\View $block */
/** @var \Magento\Framework\Escaper $escaper */

use MageOS\Blog\ViewModel\Category\Detail as CategoryDetail;

/** @var CategoryDetail $viewModel */
$viewModel = $block->getData('view_model');
$category = $viewModel->getCategory();
?>
<?php if ($category !== null): ?>
    <section class="mageos-blog-category">
        <header class="mageos-blog-category__header">
            <h1 class="mageos-blog-category__title"><?= $escaper->escapeHtml($viewModel->getTitle()); ?></h1>
        </header>

        <?php $description = $viewModel->getDescription(); ?>
        <?php if ($description !== null && $description !== ''): ?>
            <div class="mageos-blog-category__description">
                <?= /** @noEscape */ $description; ?>
            </div>
        <?php endif; ?>

        <?php $posts = $viewModel->getPosts(); ?>
        <?php if ($posts === []): ?>
            <p class="mageos-blog-category__empty">
                <?= $escaper->escapeHtml(__('No posts in this category yet.')); ?>
            </p>
        <?php else: ?>
            <ul class="mageos-blog-category__posts">
                <?php foreach ($posts as $post): ?>
                    <li class="mageos-blog-category__post">
                        <h2 class="mageos-blog-category__post-title">
                            <a href="<?= $escaper->escapeUrl($viewModel->getPostUrl($post)); ?>">
                                <?= $escaper->escapeHtml($post->getTitle()); ?>
                            </a>
                        </h2>
                        <?php $publishDate = $viewModel->getFormattedPublishDate($post); ?>
                        <?php if ($publishDate !== ''): ?>
                            <time class="mageos-blog-category__post-date"><?= $escaper->escapeHtml($publishDate); ?></time>
                        <?php endif; ?>
                        <?php $excerpt = (string) $post->getShortContent(); ?>
                        <?php if ($excerpt !== ''): ?>
                            <p class="mageos-blog-category__post-excerpt"><?= $escaper->escapeHtml($excerpt); ?></p>
                        <?php endif; ?>
                    </li>
                <?php endforeach; ?>
            </ul>
        <?php endif; ?>
    </section>
<?php endif; ?>
