<?xml version="1.0" encoding="UTF-8"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">mageos_blog_post_listing.mageos_blog_post_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <buttons>
            <button name="add">
                <url path="*/*/new"/>
                <class>primary</class>
                <label translate="true">Add New Post</label>
            </button>
        </buttons>
        <spinner>mageos_blog_post_columns</spinner>
        <deps>
            <dep>mageos_blog_post_listing.mageos_blog_post_listing_data_source</dep>
        </deps>
    </settings>
    <dataSource name="mageos_blog_post_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">post_id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>MageOS_Blog::post</aclResource>
        <dataProvider class="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider" name="mageos_blog_post_listing_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>post_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <listingToolbar name="listing_top">
        <settings>
            <sticky>true</sticky>
        </settings>
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filters name="listing_filters"/>
        <massaction name="listing_massaction">
            <action name="delete">
                <settings>
                    <confirm>
                        <message translate="true">Are you sure you want to delete selected posts?</message>
                        <title translate="true">Delete</title>
                    </confirm>
                    <url path="mageos_blog/post/massDelete"/>
                    <type>delete</type>
                    <label translate="true">Delete</label>
                </settings>
            </action>
            <action name="enable">
                <settings>
                    <url path="mageos_blog/post/massEnable"/>
                    <type>enable</type>
                    <label translate="true">Publish</label>
                </settings>
            </action>
            <action name="disable">
                <settings>
                    <url path="mageos_blog/post/massDisable"/>
                    <type>disable</type>
                    <label translate="true">Unpublish</label>
                </settings>
            </action>
        </massaction>
        <paging name="listing_paging"/>
    </listingToolbar>
    <columns name="mageos_blog_post_columns">
        <settings>
            <editorConfig>
                <param name="selectProvider" xsi:type="string">mageos_blog_post_listing.mageos_blog_post_listing.mageos_blog_post_columns.ids</param>
                <param name="enabled" xsi:type="boolean">true</param>
                <param name="indexField" xsi:type="string">post_id</param>
                <param name="clientConfig" xsi:type="array">
                    <item name="saveUrl" xsi:type="url" path="mageos_blog/post/inlineEdit"/>
                    <item name="validateBeforeSave" xsi:type="boolean">false</item>
                </param>
            </editorConfig>
            <childDefaults>
                <param name="fieldAction" xsi:type="array">
                    <item name="provider" xsi:type="string">mageos_blog_post_listing.mageos_blog_post_listing.mageos_blog_post_columns_editor</item>
                    <item name="target" xsi:type="string">startEdit</item>
                    <item name="params" xsi:type="array">
                        <item name="0" xsi:type="string">${ $.$data.rowIndex }</item>
                        <item name="1" xsi:type="boolean">true</item>
                    </item>
                </param>
            </childDefaults>
        </settings>
        <selectionsColumn name="ids">
            <settings>
                <indexField>post_id</indexField>
            </settings>
        </selectionsColumn>
        <column name="post_id">
            <settings>
                <filter>textRange</filter>
                <sorting>asc</sorting>
                <label translate="true">ID</label>
            </settings>
        </column>
        <column name="title">
            <settings>
                <editor>
                    <editorType>text</editorType>
                    <validation>
                        <rule name="required-entry" xsi:type="boolean">true</rule>
                    </validation>
                </editor>
                <filter>text</filter>
                <label translate="true">Title</label>
            </settings>
        </column>
        <column name="url_key">
            <settings>
                <editor>
                    <editorType>text</editorType>
                </editor>
                <filter>text</filter>
                <label translate="true">URL Key</label>
            </settings>
        </column>
        <column name="status" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <options class="MageOS\Blog\Ui\Component\Listing\Column\PostStatusOptions"/>
                <dataType>select</dataType>
                <filter>select</filter>
                <editor>
                    <editorType>select</editorType>
                </editor>
                <label translate="true">Status</label>
            </settings>
        </column>
        <column name="publish_date" class="Magento\Ui\Component\Listing\Columns\Date" component="Magento_Ui/js/grid/columns/date">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <label translate="true">Publish Date</label>
            </settings>
        </column>
        <column name="author_id" class="MageOS\Blog\Ui\Component\Listing\Column\AuthorName">
            <settings>
                <bodyTmpl>ui/grid/cells/html</bodyTmpl>
                <sortable>true</sortable>
                <label translate="true">Author</label>
            </settings>
        </column>
        <actionsColumn name="actions" class="MageOS\Blog\Ui\Component\Listing\Column\PostActions">
            <settings>
                <indexField>post_id</indexField>
                <resizeEnabled>false</resizeEnabled>
                <resizeDefaultWidth>107</resizeDefaultWidth>
            </settings>
        </actionsColumn>
    </columns>
</listing>
