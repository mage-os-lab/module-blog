<?xml version="1.0" encoding="UTF-8"?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">mageos_blog_author_form.mageos_blog_author_form_data_source</item>
        </item>
        <item name="label" xsi:type="string" translate="true">Blog Author</item>
        <item name="template" xsi:type="string">templates/form/collapsible</item>
    </argument>
    <settings>
        <buttons>
            <button name="save" class="MageOS\Blog\Block\Adminhtml\Author\Edit\SaveButton"/>
            <button name="delete" class="MageOS\Blog\Block\Adminhtml\Author\Edit\DeleteButton"/>
            <button name="back" class="MageOS\Blog\Block\Adminhtml\Author\Edit\BackButton"/>
        </buttons>
        <namespace>mageos_blog_author_form</namespace>
        <dataScope>data</dataScope>
        <deps>
            <dep>mageos_blog_author_form.mageos_blog_author_form_data_source</dep>
        </deps>
    </settings>
    <dataSource name="mageos_blog_author_form_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_Ui/js/form/provider</item>
            </item>
        </argument>
        <settings>
            <submitUrl path="*/*/save"/>
        </settings>
        <dataProvider class="MageOS\Blog\Ui\DataProvider\Author\Form\DataProvider" name="mageos_blog_author_form_data_source">
            <settings>
                <requestFieldName>author_id</requestFieldName>
                <primaryFieldName>author_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>

    <fieldset name="general" sortOrder="10">
        <settings>
            <label translate="true">General</label>
            <collapsible>true</collapsible>
            <opened>true</opened>
        </settings>
        <field name="name" formElement="input" sortOrder="10">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Name</label>
                <dataScope>name</dataScope>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>
        <field name="slug" formElement="input" sortOrder="20">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Slug</label>
                <dataScope>slug</dataScope>
                <notice translate="true">Leave empty to auto-generate from name.</notice>
            </settings>
        </field>
        <field name="is_active" formElement="select" sortOrder="30">
            <settings>
                <dataType>boolean</dataType>
                <label translate="true">Active</label>
                <dataScope>is_active</dataScope>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="Magento\Config\Model\Config\Source\Yesno"/>
                    </settings>
                </select>
            </formElements>
        </field>
    </fieldset>

    <fieldset name="profile" sortOrder="20">
        <settings>
            <label translate="true">Profile</label>
            <collapsible>true</collapsible>
        </settings>
        <field name="bio" formElement="wysiwyg" sortOrder="10">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Bio</label>
                <dataScope>bio</dataScope>
            </settings>
            <formElements>
                <wysiwyg>
                    <settings>
                        <wysiwyg>true</wysiwyg>
                        <rows>10</rows>
                    </settings>
                </wysiwyg>
            </formElements>
        </field>
        <field name="avatar" formElement="fileUploader" sortOrder="20">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Avatar</label>
                <dataScope>avatar</dataScope>
            </settings>
            <formElements>
                <fileUploader>
                    <settings>
                        <uploaderConfig>
                            <param name="url" xsi:type="url" path="mageos_blog/author/uploadImage/type/avatar"/>
                        </uploaderConfig>
                        <allowedExtensions>jpg jpeg png gif webp</allowedExtensions>
                        <maxFileSize>4194304</maxFileSize>
                    </settings>
                </fileUploader>
            </formElements>
        </field>
        <field name="email" formElement="input" sortOrder="30">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Email</label>
                <dataScope>email</dataScope>
            </settings>
        </field>
        <field name="twitter" formElement="input" sortOrder="40">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Twitter</label>
                <dataScope>twitter</dataScope>
            </settings>
        </field>
        <field name="linkedin" formElement="input" sortOrder="50">
            <settings>
                <dataType>text</dataType>
                <label translate="true">LinkedIn</label>
                <dataScope>linkedin</dataScope>
            </settings>
        </field>
        <field name="website" formElement="input" sortOrder="60">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Website</label>
                <dataScope>website</dataScope>
            </settings>
        </field>
    </fieldset>
</form>
